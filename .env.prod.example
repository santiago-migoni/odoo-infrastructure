# Copiar a .env.prod y completar con valores reales. .env.prod nunca se versiona.
# Las mismas credenciales de Postgres se repiten bajo distintos nombres porque
# cada imagen (postgres, pgbouncer, odoo) espera su propia convención de variable.

# db (postgres:16-alpine)
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=odoo

# pgbouncer (edoburu/pgbouncer) — mismas credenciales que arriba
DB_USER=odoo
DB_PASSWORD=changeme

# odoo (imagen oficial) — mismas credenciales que arriba, conectando vía pgbouncer
USER=odoo
PASSWORD=changeme
