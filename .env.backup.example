# Copiar a .env.backup y completar con valores reales. .env.backup nunca se
# versiona. BACKUP_DB_PASSWORD también se usa por scripts/setup-backup-role.sh
# (vía POSTGRES_USER admin de .env.prod) para crear el rol la primera vez.

# Conexión a Postgres (rol backup_readonly, solo SELECT)
PGHOST=db
PGUSER=backup_readonly
PGPASSWORD=changeme
PGDATABASE=odoo
# BACKUP_DB_PASSWORD debe ser EL MISMO valor que PGPASSWORD arriba — es la
# contraseña con la que scripts/setup-backup-role.sh crea el usuario
# backup_readonly, y con la que este contenedor se autentica después.
BACKUP_DB_PASSWORD=changeme

# Cifrado
GPG_PASSPHRASE=changeme

# Destino de rclone. En prod: r2:nombre-del-bucket (con RCLONE_CONFIG_R2_*
# seteados). En test: una ruta de filesystem plana, ej. /tmp/backup-test
RCLONE_DEST=/tmp/backup-test
RCLONE_CONFIG_R2_TYPE=s3
RCLONE_CONFIG_R2_PROVIDER=Cloudflare
RCLONE_CONFIG_R2_ACCESS_KEY_ID=changeme
RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=changeme
RCLONE_CONFIG_R2_ENDPOINT=https://changeme.r2.cloudflarestorage.com

# Copia local (bind mount, ver docker-compose.backup.yml)
LOCAL_BACKUP_DIR=/backups
