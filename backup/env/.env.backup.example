# Copiar a .env.backup y completar con valores reales. .env.backup nunca se
# versiona. BACKUP_DB_PASSWORD también se usa por scripts/setup-backup-role.sh
# (vía POSTGRES_USER admin de .env.prod) para crear el rol la primera vez.

# Conexión a Postgres (rol backup_readonly, solo SELECT)
PGHOST=db
PGUSER=backup_readonly
PGPASSWORD=changeme
PGDATABASE=odoo
# BACKUP_DB_PASSWORD debe ser EL MISMO valor que PGPASSWORD arriba — es la
# contraseña con la que scripts/setup-backup-role.sh crea el usuario
# backup_readonly, y con la que este contenedor se autentica después.
BACKUP_DB_PASSWORD=changeme

# Cifrado de restic. Passphrase única, compartida por ambos repos (local y R2).
# Si se pierde, los backups son irrecuperables — guardar fuera del servidor.
RESTIC_PASSWORD=changeme

# Repo local (bind mount, ver docker-compose.backup.yml). Restore rápido.
RESTIC_REPOSITORY_LOCAL=/backups/restic

# Repo R2 (off-site). En prod: backend S3 de restic apuntando al bucket.
# En test: una ruta de filesystem plana (ej. /backups/restic-r2-test) — restic
# trata cualquier path como repo local, sin necesidad de credenciales S3.
RESTIC_REPOSITORY_R2=s3:https://changeme.r2.cloudflarestorage.com/nombre-del-bucket
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
