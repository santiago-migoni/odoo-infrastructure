# Copiar a .env.staging y completar con valores reales. .env.staging nunca
# se versiona. Las mismas credenciales se repiten bajo distintos nombres
# porque cada imagen (postgres, pgbouncer, odoo, postgres-exporter) espera
# su propia convención de variable — mismo patrón que .env.prod.example.

# db (postgres:16-alpine) — POSTGRES_DB no va acá, está fijo en
# docker-compose.staging.yml (odoo_staging), no es un secreto
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme

# pgbouncer (edoburu/pgbouncer) — mismas credenciales que arriba
DB_USER=odoo
DB_PASSWORD=changeme

# odoo-staging (imagen propia) — mismas credenciales que arriba, conectando vía pgbouncer
USER=odoo
PASSWORD=changeme

# postgres-exporter — connection string propia (mismo host/user/password que arriba,
# apuntando directo a db:5432, no a pgbouncer)
DATA_SOURCE_NAME=postgresql://odoo:changeme@db:5432/odoo_staging?sslmode=disable

# Restore desde el repo restic LOCAL (ver feature 004-backup-restic) — nunca R2
RESTIC_PASSWORD=changeme
RESTIC_REPOSITORY_LOCAL=/backups/restic
