# Copiar a .env.monitoring y completar con valores reales. .env.monitoring
# nunca se versiona.

# postgres-exporter-prod — rol de solo lectura (pg_monitor), creado por
# scripts/setup-monitoring-role.sh. Conecta directo a db:5432, no a pgbouncer.
DATA_SOURCE_NAME=postgresql://monitoring:changeme@db:5432/odoo?sslmode=disable

# grafana — admin inicial
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
GF_SERVER_ROOT_URL=https://grafana.miempresa.com

# grafana — SMTP para Grafana Alerting (contact point de alerting.yml)
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.example.com:587
GF_SMTP_USER=changeme
GF_SMTP_PASSWORD=changeme
GF_SMTP_FROM_ADDRESS=grafana@miempresa.com

# grafana — permite referenciar variables de entorno (${OPERATOR_EMAIL}) en
# los YAML de provisioning, para no hardcodear el destinatario de alertas
GF_ENABLE_ENVVAR_EXPANSION=true
OPERATOR_EMAIL=operador@miempresa.com
